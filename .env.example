# LexAI environment configuration.
# Every provider is selected by name here. Swapping a provider means changing
# only these values + adding the implementation under src/providers/<kind>/.
# Nothing in src/pages ever reads these directly.

# --- Provider selection ---
VITE_AI_PROVIDER=mock            # mock | openai | claude | gemini | ollama | deepseek | qwen
VITE_AUTH_PROVIDER=local         # local | supabase  (local = demo auth in localStorage)
VITE_DATABASE_PROVIDER=local     # local | sqlite | postgres | supabase | firebase | mongodb
VITE_STORAGE_PROVIDER=local      # local | google_drive | supabase | s3 | r2 (case/draft files only)
VITE_SEARCH_PROVIDER=local       # local | meilisearch | elastic
VITE_CITATION_PROVIDER=local     # local | indiankanoon | casemine | verdictum | sci-portal
VITE_OCR_PROVIDER=mock           # mock | tesseract | textract | gvision
VITE_PREFERENCES_PROVIDER=local  # local (client UI preferences: view modes, filters)

# --- Credentials (only read by the matching provider implementation) ---
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_GEMINI_API_KEY=
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# MongoDB Atlas Data API (the only way to reach MongoDB from a browser SPA
# with no backend of your own — a raw mongodb:// driver can't run client-side).
VITE_MONGO_DATA_API_URL=
VITE_MONGO_DATA_API_KEY=
VITE_MONGO_DATA_SOURCE=
VITE_MONGO_DATABASE=
# Firebase Firestore (REST — no SDK). Reached via the Firestore REST API using
# the project id + Web API key; security rules govern access. An OAuth bearer
# token can be supplied instead for server-side / privileged use.
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_ACCESS_TOKEN=
VITE_INDIANKANOON_API_KEY=

# --- Cloud storage / sync (case & draft files only; needs a backend for real providers) ---
VITE_STORAGE_ROOT_FOLDER=LexAI
VITE_AUTO_SYNC_ENABLED=true
VITE_AUTO_SAVE_INTERVAL=5000     # ms; draft editor auto-save cadence
VITE_SUPABASE_BUCKET=case-files
# Google Drive secret + refresh token MUST be held by a backend, never the frontend bundle.
VITE_GOOGLE_DRIVE_CLIENT_ID=
VITE_GOOGLE_DRIVE_REFRESH_TOKEN=
